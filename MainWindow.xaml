<Window x:Class="CyberBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberShield Assistant"
        Height="750"
        Width="950"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#101820">

    <Window.Resources>

        <!-- Rounded Button -->
        <Style TargetType="Button">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#008CFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

    </Window.Resources>

    <Grid Margin="15">

        <Grid.RowDefinitions>

            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>

        </Grid.RowDefinitions>

        <!-- ========================= -->
        <!-- HEADER -->
        <!-- ========================= -->

        <Border Grid.Row="0"
                Background="#16213E"
                CornerRadius="15"
                Padding="20"
                Margin="0,0,0,10">

            <StackPanel HorizontalAlignment="Center">

                <Image x:Name="logo" Source="/logo.png"
                       Width="804"
                       Height="301"
                       Margin="0,0,0,10" Stretch="Fill"/>

                <TextBlock
                    Text="CYBERSHIELD ASSISTANT"
                    FontSize="30"
                    FontWeight="Bold"
                    Foreground="#4FC3F7"
                    HorizontalAlignment="Center" Height="35"/>

                <TextBlock
                    Text="AI Cybersecurity Awareness Assistant"
                    FontSize="16"
                    Foreground="White"
                    HorizontalAlignment="Center" Height="30"/>

            </StackPanel>

        </Border>

        <!-- ========================= -->
        <!-- CHAT AREA -->
        <!-- ========================= -->

        <Border Grid.Row="1"
                CornerRadius="15"
                Background="#1B263B"
                Padding="10">

            <TextBox
                x:Name="ChatDisplay"
                Background="#1B263B"
                Foreground="White"
                FontFamily="Consolas"
                FontSize="15"
                BorderThickness="0"
                TextWrapping="Wrap"
                VerticalScrollBarVisibility="Auto"
                AcceptsReturn="True"
                IsReadOnly="True"/>

        </Border>

        <!-- ========================= -->
        <!-- INPUT -->
        <!-- ========================= -->

        <Grid Grid.Row="2"
              Margin="0,15,0,10">

            <Grid.ColumnDefinitions>

                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="140"/>

            </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0"
                Background="#243B55"
                CornerRadius="10">

                <TextBox
                    x:Name="UserInput"
                    FontSize="15"
                    Foreground="White"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="10"/>

            </Border>

            <Button
                x:Name="SendButton"
                Grid.Column="1"
                Content="SEND"
                Click="SendButton_Click"/>

        </Grid>

        <!-- ========================= -->
        <!-- FOOTER -->
        <!-- ========================= -->

        <Grid Grid.Row="3">

            <Grid.ColumnDefinitions>

                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>

            </Grid.ColumnDefinitions>

            <Button
                x:Name="ClearButton"
                Grid.Column="0"
                Width="120"
                Content="Clear Chat"
                Click="ClearButton_Click"/>

            <TextBlock
                Grid.Column="1"
                Text="🟢 CyberShield Ready"
                Foreground="Lime"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                FontWeight="Bold"
                FontSize="14"/>

            <Button
                x:Name="ExitButton"
                Grid.Column="2"
                Width="100"
                Content="Exit"
                Click="ExitButton_Click"/>

        </Grid>

    </Grid>

</Window>