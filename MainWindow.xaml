<Window x:Class="CyberBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberShield Assistant"
        Height="750"
        Width="950"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#101820"
        Loaded="MainWindow_Loaded">

    <Window.Resources>

        <!-- Rounded Button -->
        <Style TargetType="Button">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#008CFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

    </Window.Resources>

    <Grid Margin="15">

        <TabControl
        x:Name="MainTabs"
        FontSize="15">

            <!-- ========================= -->
            <!-- TAB 1 : CYBERSHIELD -->
            <!-- ========================= -->

            <TabItem Header="💬 CyberShield Assistant">

                <!--
                Move your CURRENT chatbot interface here.

                Everything you already have goes inside this Grid:
                • Logo
                • ChatDisplay
                • UserInput
                • Send Button
                • Clear Button
                • Exit Button
            -->

                <Grid x:Name="ChatTabGrid">
                    <Grid Margin="15">

                        <Grid.RowDefinitions>

                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>

                        </Grid.RowDefinitions>

                        <!-- ========================= -->
                        <!-- HEADER -->
                        <!-- ========================= -->

                        <Border Grid.Row="0"
                Background="#16213E"
                CornerRadius="15"
                Padding="20"
                Margin="0,0,0,10">

                            <StackPanel HorizontalAlignment="Center">

                                <Image x:Name="logo" Source="/logo.png"
                       Width="804"
                       Height="175"
                       Margin="0,0,0,10" Stretch="Fill"/>

                                <TextBlock
                    Text="CYBERSHIELD ASSISTANT"
                    FontSize="30"
                    FontWeight="Bold"
                    Foreground="#4FC3F7"
                    HorizontalAlignment="Center" Height="30" RenderTransformOrigin="0.515,0.557"/>

                                <TextBlock
                    Text="AI Cybersecurity Awareness Assistant"
                    FontSize="16"
                    Foreground="White"
                    HorizontalAlignment="Center" Height="19"/>

                            </StackPanel>

                        </Border>

                        <!-- ========================= -->
                        <!-- CHAT AREA -->
                        <!-- ========================= -->

                        <Border Grid.Row="1"
                CornerRadius="15"
                Background="#1B263B"
                Padding="10">

                            <TextBox
                x:Name="ChatDisplay"
                Background="#1B263B"
                Foreground="White"
                FontFamily="Consolas"
                FontSize="15"
                BorderThickness="0"
                TextWrapping="Wrap"
                VerticalScrollBarVisibility="Auto"
                AcceptsReturn="True"
                IsReadOnly="True"/>

                        </Border>

                        <!-- ========================= -->
                        <!-- INPUT -->
                        <!-- ========================= -->

                        <Grid Grid.Row="2"
              Margin="0,15,0,10">

                            <Grid.ColumnDefinitions>

                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="140"/>

                            </Grid.ColumnDefinitions>

                            <Border
                Grid.Column="0"
                Background="#243B55"
                CornerRadius="10">

                                <TextBox
                    x:Name="UserInput"
                    FontSize="15"
                    Foreground="White"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="10"/>

                            </Border>

                            <Button
                x:Name="SendButton"
                Grid.Column="1"
                Content="SEND"
                Click="SendButton_Click"/>

                        </Grid>

                        <!-- ========================= -->
                        <!-- FOOTER -->
                        <!-- ========================= -->

                        <Grid Grid.Row="3">

                            <Grid.ColumnDefinitions>

                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>

                            </Grid.ColumnDefinitions>

                            <Button
                x:Name="ClearButton"
                Grid.Column="0"
                Width="120"
                Content="Clear Chat"
                Click="ClearButton_Click"/>

                            <TextBlock
                Grid.Column="1"
                Text="🟢 CyberShield Ready"
                Foreground="Lime"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                FontWeight="Bold"
                FontSize="14"/>

                            <Button
                x:Name="ExitButton"
                Grid.Column="2"
                Width="100"
                Content="Exit"
                Click="ExitButton_Click"/>

                        </Grid>

                    </Grid>
                </Grid>

            </TabItem>

            <!-- ========================= -->
            <!-- TAB 2 : TASK ASSISTANT -->
            <!-- ========================= -->

            <TabItem Header="📋 Task Assistant">

                <Grid Margin="20">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="71.426"/>
                        <ColumnDefinition Width="58.574"/>
                        <ColumnDefinition Width="107*"/>
                        <ColumnDefinition Width="265*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ========================= -->
                    <!-- TITLE -->
                    <!-- ========================= -->

                    <TextBlock
            Grid.Column="0"
            Text="Task Title:"
            FontWeight="Bold"
            FontSize="15"
            Foreground="White"
            VerticalAlignment="Center" Grid.ColumnSpan="2"/>

                    <TextBox
            x:Name="TaskTitleBox"
            Grid.Row="0"
            Grid.Column="2"
            Height="35"
            Margin="10,5,10,5" Grid.ColumnSpan="2"/>

                    <!-- ========================= -->
                    <!-- DESCRIPTION -->
                    <!-- ========================= -->

                    <TextBlock
            Grid.Row="1"
            Grid.Column="0"
            Text="Description:"
            FontWeight="Bold"
            FontSize="15"
            Foreground="White"
            VerticalAlignment="Center" Grid.ColumnSpan="2"/>

                    <TextBox
            x:Name="TaskDescriptionBox"
            Grid.Row="1"
            Grid.Column="2"
            Height="70"
            Margin="10,5,10,5"
            AcceptsReturn="True"
            TextWrapping="Wrap" Grid.ColumnSpan="2"/>

                    <!-- ========================= -->
                    <!-- REMINDER -->
                    <!-- ========================= -->

                    <TextBlock
            Grid.Row="2"
            Grid.Column="0"
            Text="Reminder:"
            FontWeight="Bold"
            FontSize="15"
            Foreground="White"
            VerticalAlignment="Center" Grid.ColumnSpan="2"/>

                    <TextBox
            x:Name="ReminderBox"
            Grid.Row="2"
            Grid.Column="2"
            Height="35"
            Margin="10,5,10,5"
            ToolTip="Example: Remind me in 5 days" Grid.ColumnSpan="2"/>

                    <!-- ========================= -->
                    <!-- ADD BUTTON -->
                    <!-- ========================= -->

                    <Button
            x:Name="AddTaskButton"
            Grid.Row="3"
            Width="180"
            Height="40"
            Margin="3,15,0,15"
            HorizontalAlignment="Left"
            Content="➕ Add Task"
            Click="AddTask_Click" Grid.Column="3"/>

                    <!-- ========================= -->
                    <!-- TASK LIST -->
                    <!-- ========================= -->

                    <ListBox
                        x:Name="TaskList"
                        Grid.Row="4"
                        Grid.ColumnSpan="4"
                        Margin="0,15,0,15"
                        FontFamily="Consolas"
                        FontSize="14"
                        />

                    <!-- ========================= -->
                    <!-- ACTION BUTTONS -->
                    <!-- ========================= -->

                    <StackPanel
            Grid.Row="5"
            Orientation="Horizontal"
            HorizontalAlignment="Left"
            Margin="57,15,0,15" Grid.Column="2" Grid.ColumnSpan="2">

                        <Button
                x:Name="CompleteTaskButton"
                Width="180"
                Height="40"
                Margin="5"
                Content="✅ Mark Complete"
                Click="CompleteTask_Click"/>

                        <Button
                x:Name="DeleteTaskButton"
                Width="150"
                Height="40"
                Margin="5"
                Content="🗑 Delete Task"
                Click="DeleteTask_Click"/>

                        <Button
                x:Name="RefreshTaskButton"
                Width="140"
                Height="40"
                Margin="5"
                Content="🔄 Refresh"
                Click="RefreshTasks_Click"/>

                    </StackPanel>

                </Grid>

            </TabItem>

            <!-- ========================= -->
            <!-- TAB 3 : QUIZ -->
            <!-- ========================= -->

            <TabItem Header="🎮 Cybersecurity Quiz">
                <Grid Margin="20">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- TITLE -->
                    <TextBlock
            Text="Cybersecurity Quiz"
            FontSize="24"
            FontWeight="Bold"
            Foreground="White"
            HorizontalAlignment="Center"
            Margin="0,0,0,20"/>

                    <!-- QUESTION -->
                    <TextBlock
            x:Name="QuestionText"
            Grid.Row="1"
            FontSize="18"
            Foreground="White"
            TextWrapping="Wrap"
            Margin="0,10"/>

                    <!-- OPTIONS -->
                    <StackPanel
            x:Name="OptionsPanel"
            Grid.Row="2"
            Margin="0,10,0,50"/>

                    <!-- SUBMIT BUTTON -->
                    <Button
            Grid.Row="3"
            Content="Submit Answer"
            Width="180"
            HorizontalAlignment="Center"
            Click="SubmitAnswer_Click"/>

                    <!-- RESULT -->
                    <TextBlock
            x:Name="ResultText"
            Grid.Row="4"
            FontSize="16"
            Foreground="LightGreen"
            TextAlignment="Center"
            Margin="0,10"/>

                </Grid>
            </TabItem>

            <!-- ========================= -->
            <!-- TAB 4 : ACTIVITY LOG -->
            <!-- ========================= -->

            <TabItem Header="📊 Activity Log">
                <Grid Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="219*"/>
                        <ColumnDefinition Width="218*"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition Height="Auto" MinHeight="98.09"/>
                    </Grid.RowDefinitions>

                    <!-- LOG DISPLAY -->
                    <TextBox
            x:Name="LogDisplay"
            Grid.Row="0"
            IsReadOnly="True"
            TextWrapping="Wrap"
            VerticalScrollBarVisibility="Auto"
            FontSize="14"
            Foreground="White"
            Background="#222"
            Margin="0,0,0,10" Grid.ColumnSpan="2"/>

                    <!-- BUTTONS -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Grid.ColumnSpan="2" Margin="246,10,0,46" Width="436" Grid.Row="1" RenderTransformOrigin="0.361,0.294">

                        <Button
                Content="Clear Log"
                Width="176"
                Click="ClearLog_Click" Height="34"/>

                        <Button
                Content="Refresh"
                Width="159"
                Click="RefreshLog_Click" Height="32"/>

                    </StackPanel>

                </Grid>

            </TabItem>


        </TabControl>

    </Grid>

</Window>